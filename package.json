{
  "name": "agentic-web-automation",
  "version": "1.0.0",
  "description": "Autonomous AI Agent for op-maps.com gameplay",
  "main": "agent/core.js",
  "scripts": {
    "start:debug": "node --inspect agent/core.js --mode=debug",
    "start:learning": "node agent/core.js --mode=learning",
    "start:agent": "node agent/core.js --mode=autonomous",
    "simulate:action": "node tests/simulate.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "replay:mission": "node learning/replay.js"
  },
  "keywords": [
    "ai",
    "agent",
    "automation",
    "gaming",
    "playwright",
    "openai"
  ],
  "author": "York1824",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.40.0",
    "openai": "^4.24.0",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^8.54.0",
    "nodemon": "^3.0.2"
  }
}
