# OpenAI API (für LLM-Entscheidungen)
OPENAI_API_KEY=sk-...

# op-maps Login
OPMAPS_EMAIL=dein@email.com
OPMAPS_PASSWORD=dein_passwort

# GitHub (für Feedback-Logging)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=York1824/agentic-web-automation

# Agent-Konfiguration
AGENT_MODE=AUTONOMOUS
DECISION_TIMEOUT=30000
SCREENSHOT_INTERVAL=5000
HEADLESS=true
RECORD_VIDEO=true

# Strategische Einstellungen
STRATEGY_MODE=balanced
THREAT_THRESHOLD=5
DEFENSE_THRESHOLD=0.3
MIN_TROOPS_DEFEND=10
MIN_TROOPS_ATTACK=15
